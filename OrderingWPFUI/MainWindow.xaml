<Window x:Class="OrderingWPFUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OrderingWPFUI"
        xmlns:v="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

    <Window.Resources>

        <v:BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <Style TargetType="TextBlock" x:Key="InnerTextBlocks">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Place Order" FontSize="20" HorizontalAlignment="Center"/>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="12" Background="White" BorderBrush="Black" Margin="10" Padding="5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Item" Style="{StaticResource InnerTextBlocks}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="Quantity" Style="{StaticResource InnerTextBlocks}"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="City" Style="{StaticResource InnerTextBlocks}"/>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="State" Style="{StaticResource InnerTextBlocks}"/>


                <ComboBox Grid.Column="1" ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedItem, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}"
                          DisplayMemberPath="Name" Margin="5,5"/>
                <TextBox Grid.Row="1" Grid.Column="1"  Text="{Binding QuantityText, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderBrush="Gray" Margin="5"/>
                <TextBox Grid.Row="2" Grid.Column="1"  Text="{Binding City, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderBrush="Gray" Margin="5"/>
                <!--<TextBox Grid.Row="3" Grid.Column="1"  Text="{Binding SelectedState, ValidatesOnNotifyDataErrors=True, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Stretch" BorderBrush="Gray" Margin="5"/>-->


                <ComboBox Grid.Row="3" Grid.Column="1" ItemsSource="{Binding States}" SelectedItem="{Binding SelectedState, UpdateSourceTrigger=PropertyChanged}"
           Margin="5,5"/>
                <ProgressBar Grid.Row="4" Grid.ColumnSpan="2" Margin="5,15" Height="5" IsIndeterminate="True" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

                <Button Content="Place Order" Grid.Row="5" Grid.ColumnSpan="2" Command="{Binding PlaceOrderCommand}" Margin="5,5" Height="25"/>
            </Grid>
        </Border>

        <Button Grid.Row="2" Command="{Binding ResetCommand}" Content="Reset" HorizontalAlignment="Right" Margin="20,5" />
        <StackPanel Grid.Row="3"
                    Margin="0,16,0,0">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Tomato"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />
            <TextBlock Text="{Binding ConfirmationMessage}"
                       Foreground="Green"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap" />
        </StackPanel>
    </Grid>
</Window>
